\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemetechnikum-fonts}[2026/04/09 Extra Noto font families for multi-script support]

% Requires fontspec (loaded by the theme or by the user)
\RequirePackage{fontspec}

% Arabic
\newfontfamily\arabicfont{NotoSansArabic-Regular.ttf}[Script=Arabic]
\newfontfamily\arabicseriffont{NotoNaskhArabic-Regular.ttf}[Script=Arabic]

% Urdu (Nastaliq)
\newfontfamily\urdufont{NotoNastaliqUrdu-Regular.ttf}[Script=Arabic]

% Armenian
\newfontfamily\armenianfont{NotoSansArmenian-Regular.ttf}[Script=Armenian]
\newfontfamily\armenianseriffont{NotoSerifArmenian-Regular.ttf}[Script=Armenian]

% Bengali
\newfontfamily\bengalifont{NotoSansBengali-Regular.ttf}[Script=Bengali]
\newfontfamily\bengaliseriffont{NotoSerifBengali-Regular.ttf}[Script=Bengali]

% Devanagari
\newfontfamily\devanagarifont{NotoSansDevanagari-Regular.ttf}[Script=Devanagari]
\newfontfamily\devanagariseriffont{NotoSerifDevanagari-Regular.ttf}[Script=Devanagari]

% Georgian
\newfontfamily\georgianfont{NotoSansGeorgian-Regular.ttf}[Script=Georgian]
\newfontfamily\georgianseriffont{NotoSerifGeorgian-Regular.ttf}[Script=Georgian]

% Hebrew
\newfontfamily\hebrewfont{NotoSansHebrew-Regular.ttf}[Script=Hebrew]
\newfontfamily\hebrewseriffont{NotoSerifHebrew-Regular.ttf}[Script=Hebrew]

% Tamil
\newfontfamily\tamilfont{NotoSansTamilUI-Regular.ttf}[Script=Tamil]
\newfontfamily\tamilseriffont{NotoSerifTamil-Regular.ttf}[Script=Tamil]

% Thai
\newfontfamily\thaifont{NotoSansThai-Regular.ttf}[Script=Thai]
\newfontfamily\thaiseriffont{NotoSerifThai-Regular.ttf}[Script=Thai]

% CJK — Japanese
\newfontfamily\japanesefont{NotoSansJP-Regular.otf}
\newfontfamily\japaneseseriffont{NotoSerifJP-Regular.otf}

% CJK — Korean
\newfontfamily\koreanfont{NotoSansKR-Regular.otf}
\newfontfamily\koreanseriffont{NotoSerifKR-Regular.otf}

% CJK — Simplified Chinese
\newfontfamily\chinesefont{NotoSansSC-Regular.otf}
\newfontfamily\chineseseriffont{NotoSerifSC-Regular.otf}

% CJK — Traditional Chinese
\newfontfamily\chinesetcfont{NotoSansTC-Regular.otf}
\newfontfamily\chinesetcseriffont{NotoSerifTC-Regular.otf}

\endinput
